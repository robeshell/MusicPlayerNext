{
  "$schema": "../README.md",
  "specVersion": "0.1.0",
  "spacing": {
    "comment": "4 的倍数刻度；组件内部微调可用半档（2/6/10），页面级只用下列值",
    "x1": 4,
    "x2": 8,
    "x3": 12,
    "x4": 16,
    "x6": 24,
    "x8": 32
  },
  "radii": {
    "control": 10,
    "card": 14,
    "menu": 12,
    "sheet": 18,
    "dialog": 20,
    "pill": 999,
    "checkbox": 5,
    "tooltip": 8
  },
  "typography": {
    "fontFamily": ".SF Pro Text",
    "fontFamilyFallback": ["PingFang SC", "Microsoft YaHei", "Noto Sans CJK SC", "Roboto", "sans-serif"],
    "weights": {
      "comment": "层级靠字重驱动（w600→w700→w800）+ 颜色（primary→secondary→muted），不靠字号堆叠",
      "body": 400,
      "emphasis": 600,
      "strong": 700,
      "display": 800
    },
    "tracking": {
      "headlineLarge": -0.8,
      "headlineMedium": -0.55,
      "titleLarge": -0.25,
      "pageTitle": -0.55
    },
    "sizes": {
      "pageTitle": [26, 28],
      "rowTitle": 13.5,
      "rowSubtitle": 11.5,
      "navLabel": 10.5,
      "chipLabel": 12,
      "sectionSubtitle": 12.5
    }
  },
  "motion": {
    "uiFast": { "durationMs": 140, "curve": "easeOut" },
    "uiStandard": { "durationMs": 160, "curve": "easeOutCubic" },
    "paletteTransition": { "durationMs": 420, "comment": "皮肤/配色切换；深夜皮肤 520" },
    "ambient": { "durationS": 14, "comment": "环境动效（氛围背景等），reduced-motion 时按 motionStrength 衰减" }
  },
  "tapTargets": {
    "buttonMin": 36,
    "iconButton": 40,
    "listRowMin": 46,
    "chipHeight": 32
  },
  "breakpoints": {
    "windowClass": {
      "compact": "width <= 600 或 height < 600（移动）",
      "medium": "桌面 width < 1100；移动 width < 1000",
      "wide": "桌面 width >= 1100；移动 width >= 1000"
    },
    "mobileShell": "非桌面平台且（width < 820 或 height < 600）",
    "menuAdaptive": 680,
    "settingsMaxContentWidth": 920
  },
  "layoutMetrics": {
    "pageGutter": { "compact": 16, "medium": 24, "wide": 32 },
    "contentBottomPadding": { "mobileShell": 140, "desktop": 96 },
    "sidebarWidth": { "medium": 216, "wide": 236 },
    "titlebarInset": { "macOS": 38, "windows": 44 }
  },
  "derivedAlphas": {
    "comment": "全品牌通用的派生透明度；实现方不得另行发明数值",
    "border": { "light": "black@0.08", "dark": "white@0.10" },
    "hairline": { "light": "black@0.055", "dark": "white@0.065" },
    "disabledBorder": { "light": "black@0.04", "dark": "white@0.05" },
    "subtleFill": { "light": "black@0.045", "dark": "white@0.055" },
    "disabledSubtle": { "light": "black@0.024", "dark": "white@0.028" },
    "stateLayer": {
      "hover": "foreground@0.055~0.065",
      "pressed": "foreground@0.10",
      "focused": "accent@0.16"
    },
    "selection": {
      "rowOrSurface": "foreground@0.05~0.055",
      "accentIndicator": "accent@0.10~0.14",
      "chipSelected": "accent@0.09",
      "listTileSelected": "accent@0.035"
    },
    "barrier": { "dialogLight": "black@0.38", "dialogDark": "black@0.62" },
    "destructive": { "rest": "error@0.08", "hoverOrFocus": "error@0.12", "pressed": "error@0.16", "disabled": "error@0.025" }
  }
}
