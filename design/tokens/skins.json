{
  "$schema": "../README.md",
  "specVersion": "0.1.3",
  "comment": "皮肤预设：每个皮肤自带明暗 + 四档表面坡道 + 玻璃 token + 动效 token。已发布皮肤的 token 值是稳定承诺，不得修改；新外观只能新增皮肤。",
  "systemPseudoSkin": {
    "id": "system",
    "resolve": "按平台亮度解析：light → default，dark → deep-night",
    "note": "不是真实预设，不进 presets 列表；持久化层存 'system' 字符串"
  },
  "presets": [
    {
      "id": "default",
      "name": "默认",
      "description": "品牌的中性浅色玻璃界面",
      "brightness": "light",
      "canvas": "#F7F7F8",
      "surface": "#FAFAFB",
      "elevated": "#FFFFFF",
      "overlay": "#F1F2F4",
      "glass": {
        "canvasHighlight": "#FBFBFC",
        "surface": "#FFFFFF@0.72",
        "strongSurface": "#FFFFFF@0.87",
        "border": "black@0.07",
        "innerHighlight": "white@0.55",
        "shadow": "black@0.09",
        "primaryText": "#1C1C22",
        "secondaryText": "#5A5A62",
        "mutedText": "#77747D",
        "blur": 20,
        "strongBlur": 28
      },
      "effects": {
        "motionDurationS": 14,
        "paletteTransitionMs": 420,
        "motionStrength": 1,
        "primaryGlowOpacity": 0.9,
        "secondaryGlowOpacity": 0.72,
        "lightVeilOpacity": 0.04,
        "darkVeilOpacity": 0.12,
        "shadowScale": 1
      }
    },
    {
      "id": "pure",
      "name": "纯净",
      "description": "冷静通透的实色表面与清晰层次",
      "brightness": "light",
      "canvas": "#F1F4F8",
      "surface": "#FAFCFF",
      "elevated": "#FFFFFF",
      "overlay": "#E5EBF2",
      "glass": {
        "canvasHighlight": "#F8FBFF",
        "surface": "#FFFFFF@1.0",
        "strongSurface": "#FFFFFF@1.0",
        "border": "#526174@0.12",
        "innerHighlight": "#FFFFFF@1.0",
        "shadow": "transparent",
        "primaryText": "#18202A",
        "secondaryText": "#536171",
        "mutedText": "#718092",
        "blur": 0,
        "strongBlur": 0
      },
      "effects": {
        "motionDurationS": 26,
        "paletteTransitionMs": 240,
        "motionStrength": 0.22,
        "primaryGlowOpacity": 0.38,
        "secondaryGlowOpacity": 0.24,
        "lightVeilOpacity": 0.015,
        "darkVeilOpacity": 0.08,
        "shadowScale": 0
      },
      "note": "实色皮肤：blur=0 时组件必须跳过 BackdropFilter，shadowScale=0 时无投影。组件读 token 则此行为免费获得。"
    },
    {
      "id": "deep-night",
      "name": "深夜",
      "description": "专注于内容的低亮深色界面",
      "brightness": "dark",
      "canvas": "#0D0D0F",
      "surface": "#17171A",
      "elevated": "#202024",
      "overlay": "#29292E",
      "glass": {
        "canvasHighlight": "#17171A",
        "surface": "#17171A@0.72",
        "strongSurface": "#202024@0.90",
        "border": "white@0.11",
        "innerHighlight": "white@0.12",
        "shadow": "black@0.42",
        "primaryText": "#F7F3F4",
        "secondaryText": "white@0.60",
        "mutedText": "white@0.70",
        "blur": 20,
        "strongBlur": 28
      },
      "effects": {
        "motionDurationS": 18,
        "paletteTransitionMs": 520,
        "motionStrength": 0.68,
        "primaryGlowOpacity": 0.76,
        "secondaryGlowOpacity": 0.54,
